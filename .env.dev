# Development Environment Configuration
# Used for local development with docker-compose

# Core Runtime
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
API_GATEWAY_PORT=8000

# API Gateway
API_GATEWAY_TIMEOUT=30000
API_GATEWAY_RETRY_ATTEMPTS=3
API_GATEWAY_LOG_LEVEL=debug

# Admin Panel  
ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_PORT=3001

# Authentication
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRY=72h
ADMIN_JWT_EXPIRY=24h

# OAuth2 (optional development integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://dev_user:dev_password@postgres:5432/milonexa_dev
DATABASE_POOL_SIZE=5
DATABASE_IDLE_TIMEOUT=10000
DATABASE_SSL=false
DATABASE_LOG=true

# Cache
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_POOL_SIZE=5

# Email (development - no-op or mock)
EMAIL_SERVICE=console
EMAIL_FROM=dev@milonexa.local
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Storage
STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=milonexa-dev
MINIO_SSL=false
MAX_FILE_SIZE=52428800

# Media Settings
MEDIA_IMAGE_MAX_SIZE=5242880
MEDIA_VIDEO_MAX_SIZE=104857600
MEDIA_ALLOWED_FORMATS=jpg,jpeg,png,gif,mp4,webm,mov

# Search (Elasticsearch)
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=milonexa-dev
ELASTICSEARCH_LOG_LEVEL=info

# AI Service
AI_SERVICE_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
AI_CONTENT_MODERATION_ENABLED=true

# Monitoring & Logging
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
LOG_AGGREGATION=console

# Feature Flags
FEATURE_BETA_COLLABORATION=true
FEATURE_BETA_STREAMING=true
FEATURE_SHOP_CHECKOUT=true

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ENABLED=false
REQUIRE_HTTPS=false

# Debug
DEBUG_MODE=true
DEBUG_SQL_QUERIES=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
