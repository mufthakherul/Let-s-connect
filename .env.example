# =============================================================================
# Milonexa — Comprehensive Environment Configuration Reference
# =============================================================================
# USAGE:
#   cp .env.example .env
#   Edit .env with your real values (do NOT commit .env to version control)
#
# QUICK SECRETS GENERATOR:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32
#
# REQUIRED = must be set before first run
# OPTIONAL = has a safe default, change only if needed
# =============================================================================

# =============================================================================
# 1) CORE RUNTIME
# =============================================================================
# Application environment. Values: development | production | test
# Reason: Controls logging verbosity, error detail, and some security checks
NODE_ENV=production

# Log verbosity. Values: error | warn | info | debug
LOG_LEVEL=info

# Docker Compose project name (prefixes container/volume/network names)
COMPOSE_PROJECT_NAME=milonexa

# API version — ALWAYS v2 (v1 deprecated with RFC-8594 Sunset headers).
# Reason: Gateway and frontend both expect v2; changing this will break routing.
API_VERSION=v2

# Allow direct service port access (bypass gateway). ONLY true for local dev.
# Reason: In production, all traffic must go through the API gateway.
ALLOW_DIRECT_SERVICE_ACCESS=false

# Enable/disable global rate limiting on the API gateway.
# Set false during development to avoid throttling yourself.
RATE_LIMITING_ENABLED=true

# =============================================================================
# 2) SECURITY / TOKENS  [REQUIRED]
# =============================================================================
# JWT signing secret — used to sign and verify user session tokens.
# How to generate: openssl rand -hex 32
# Reason: If compromised, all user sessions are exposed. Use >= 32 random bytes.
JWT_SECRET=replace-with-strong-random-jwt-secret

# Data encryption key — used for encrypting sensitive data at rest (e.g. OAuth tokens).
# How to generate: openssl rand -hex 32
# Reason: Protects stored OAuth tokens and sensitive fields in the database.
ENCRYPTION_KEY=replace-with-64-char-hex-or-strong-random-key

# Internal service-to-service authentication token (Bearer).
# How to generate: openssl rand -hex 32
# Reason: Prevents unauthorized direct calls between microservices.
INTERNAL_GATEWAY_TOKEN=replace-with-strong-random-internal-token

# Notification service internal token (used by notification workflows).
# How to generate: openssl rand -hex 32
INTERNAL_NOTIFICATION_TOKEN=replace-with-strong-random-notification-token

# =============================================================================
# 3) ADMIN PANEL CONFIGURATION
# =============================================================================
# Milonexa has 8 admin interface methods. CLI is always available locally.
# All other interfaces are opt-in via profile flags below.
#
# Profiles:         docker compose --profile <profile> up
#   admin           → Admin Web React UI (port 3001)
#   admin-api       → REST API (port 8888)
#   admin-ssh       → SSH dashboard (port 2222)
#   admin-webhook   → Webhook notification hub (port 8889)
#   admin-bot-telegram → Telegram bot
#   admin-bot-slack → Slack bot (Socket Mode)
#   admin-email     → Email command interface
#   admin-ai        → AI autonomous admin agent

# --- Security service (backs all admin interfaces) ---
# Port where the dedicated security-service listens.
# Default: 9102  (do NOT change unless you have a port conflict)
SECURITY_PORT=9102

# API secret shared between the gateway and security-service.
# How to generate: openssl rand -hex 32
# Reason: Prevents unauthorized access to admin-only gateway routes.
ADMIN_API_SECRET=replace-with-admin-api-secret

# Comma-separated allowed CORS origins for the admin web UI.
# For Codespaces: https://<codespace-name>-3001.app.github.dev
# For local: https://localhost:3001,http://localhost:3001
ADMIN_CORS_ORIGINS=https://localhost:3001,http://localhost:3001

# --- Admin Authentication & Database ---
# Separate Postgres connection for admin accounts.
# How to get: use the same postgres container, point to 'admin' database.
# Reason: Isolates admin credentials from application data.
ADMIN_DB_URL=postgres://app_user:replace-with-strong-db-password@postgres:5432/admin

# Bootstrap master admin credentials (used on first run to create admin account).
# Change these immediately after first login.
ADMIN_MASTER_USERNAME=admin
ADMIN_MASTER_PASSWORD=replace-with-strong-password
# Preferred canonical names (also supported by security-service)
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_PASSWORD=replace-with-strong-password

# Admin-specific JWT secret (different from the app JWT_SECRET).
# How to generate: openssl rand -hex 32
# Reason: Admin tokens are signed with a separate key for extra isolation.
ADMIN_JWT_SECRET=replace-with-another-strong-secret

# Optional separate frontend admin port (for dev hot-reload).
REACT_APP_ADMIN_PORT=3001

# Frontend secret passed from React admin UI to backend (must match ADMIN_API_SECRET).
REACT_APP_ADMIN_SECRET=replace-with-admin-secret

# Profile activation for admin containers.
# ENABLE_ADMIN_* flags alone do not start profile-gated services.
# To auto-start both admin web + AI on plain `docker compose up`, uncomment:
COMPOSE_PROFILES=admin,admin-ai

# --- 1) Admin Web Dashboard (React UI) ---
# docker compose --profile admin up admin-web
ENABLE_ADMIN_WEB=true
ADMIN_WEB_PORT=3001

# --- 2) Admin REST API Server ---
# docker compose --profile admin-api up admin-rest-api
ENABLE_ADMIN_REST_API=false
# Port the REST API server listens on
ADMIN_API_PORT=8888
# Bearer token for REST API authentication.
# How to generate: openssl rand -hex 32
# REQUIRED if server is accessible from outside localhost.
ADMIN_API_KEY=replace-with-strong-random-key
# CORS origin for REST API
ADMIN_CORS_ORIGIN=http://localhost:3001

# --- 3) Admin SSH Dashboard ---
# docker compose --profile admin-ssh up admin-ssh
ENABLE_ADMIN_SSH=false
ADMIN_SSH_PORT=2222
# Password for SSH 'admin' login (leave empty for public-key-only auth).
# How to generate: openssl rand -base64 24
ADMIN_SSH_PASSWORD=
ADMIN_SSH_AUTHORIZED_KEYS=./admin/ssh/ssh-keys/authorized_keys
ADMIN_SSH_KEYS_DIR=./admin/ssh/ssh-keys
ADMIN_SSH_MAX_SESSIONS=5
# Idle session timeout in seconds
ADMIN_SSH_IDLE_TIMEOUT=300
ADMIN_SSH_BANNER=Milonexa Admin SSH — Authorized Access Only

# --- 4) Admin Webhook Server ---
# docker compose --profile admin-webhook up admin-webhook
ENABLE_ADMIN_WEBHOOK=false
ADMIN_WEBHOOK_PORT=8889
# How to generate: openssl rand -hex 32
ADMIN_WEBHOOK_SECRET=replace-with-strong-random-key

# --- 5) Admin Telegram Bot ---
# How to get: Talk to @BotFather on Telegram -> /newbot
# docker compose --profile admin-bot-telegram up admin-bot-telegram
ENABLE_ADMIN_BOT_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to issue admin commands.
# How to get: Send a message to @userinfobot on Telegram.
TELEGRAM_ADMIN_USER_IDS=
# Comma-separated chat/group IDs allowed for admin commands.
TELEGRAM_ADMIN_CHAT_IDS=

# --- 6) Admin Slack Bot ---
# How to get: https://api.slack.com/apps -> Create App -> Socket Mode
# docker compose --profile admin-bot-slack up admin-bot-slack
ENABLE_ADMIN_BOT_SLACK=false
# Bot OAuth token (starts with xoxb-)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=
# Signing secret for request verification (from App Credentials page)
SLACK_SIGNING_SECRET=
# Comma-separated Slack channel IDs where admin commands are allowed
SLACK_ADMIN_CHANNELS=
# Comma-separated Slack user IDs allowed to use admin commands
SLACK_ADMIN_USER_IDS=
# Port for Slack bolt HTTP mode (only used in HTTP mode, not Socket Mode)
SLACK_BOT_PORT=3003

# --- 7) Admin Email Command Interface ---
# Send email with subject "[ADMIN-CMD] <command>" to trigger admin commands.
# docker compose --profile admin-email up admin-email
ENABLE_ADMIN_EMAIL=false
ADMIN_EMAIL_USER=
ADMIN_EMAIL_PASSWORD=
ADMIN_EMAIL_IMAP_HOST=
ADMIN_EMAIL_IMAP_PORT=993
ADMIN_EMAIL_IMAP_TLS=true
ADMIN_EMAIL_SMTP_HOST=
ADMIN_EMAIL_SMTP_PORT=587
ADMIN_EMAIL_SMTP_SECURE=false
ADMIN_EMAIL_SMTP_USER=
ADMIN_EMAIL_SMTP_PASS=
ADMIN_EMAIL_FROM=
# Only these email addresses can send admin commands (security whitelist)
ADMIN_EMAIL_ALLOWED_SENDERS=
ADMIN_EMAIL_SUBJECT_PREFIX=[ADMIN-CMD]
# Optional: email body must contain this string for extra security
ADMIN_EMAIL_SIGNATURE=
# IMAP polling interval in seconds
ADMIN_EMAIL_POLL_INTERVAL=30

# --- 8) AI Autonomous Admin Agent ---
# docker compose --profile admin-ai up admin-ai
ENABLE_ADMIN_AI=false
# AI provider: demo (no API key) | ollama (local LLM) | openai | anthropic
AI_PROVIDER=ollama
# If using OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# If using Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# How often the AI agent runs its monitoring cycle (seconds)
AI_CYCLE_INTERVAL_SECONDS=60
# Run each capability every N main cycles
AI_CODE_ANALYSIS_EVERY_N_CYCLES=10
AI_DOC_GEN_EVERY_N_CYCLES=20
AI_TEST_GEN_EVERY_N_CYCLES=30
AI_FEEDBACK_EVERY_N_CYCLES=5
# Port for AI agent HTTP control/status API
AI_STATUS_PORT=8890
# Auth token for AI agent control API (leave empty only if port is firewalled)
# How to generate: openssl rand -hex 32
AI_STATUS_TOKEN=
AI_NOTIFY_EVERY_CYCLE=false
AI_EMERGENCY_NOTIFY=true
AI_AUTO_HEAL=true
AI_AUTO_SECURITY=true
# Platform API gateway URL (used for health checks)
AI_GATEWAY_URL=http://api-gateway:8000
# Minutes before pending human-approval requests auto-expire
AI_PERMISSION_TIMEOUT_MINUTES=30

# --- Advanced Admin Security ---
ENABLE_ADMIN_2FA=false
# IP whitelist for admin access (applies to REST API and SSH)
ADMIN_ALLOWED_IPS=127.0.0.1,::1
# CIDR range whitelist
ADMIN_ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8

# =============================================================================
# 4) DATABASE / SCHEMA POLICY
# =============================================================================
# Application DB user (least-privilege — used by all microservices).
# Reason: Never use the postgres superuser for application queries.
APP_DB_USER=app_user
APP_DB_PASSWORD=replace-with-strong-db-password

# Postgres container bootstrap credentials (superuser — only for container init).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Databases to auto-create on first container start (scripts/init-databases.sh).
# 'admin' is required for the security-service.
POSTGRES_MULTIPLE_DATABASES=users,content,messages,collaboration,media,shop,webhooks,streaming,admin

# Optional compatibility aliases (used by scripts and some tools).
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-strong-db-password
# Full connection URL for user-service (and default for scripts).
DATABASE_URL=postgresql://app_user:replace-with-strong-db-password@postgres:5432/users

# Schema management strategy:
#   migrate — run explicit Sequelize migrations (safer, recommended for production)
#   sync    — auto-sync Sequelize models (may drop/alter columns, dev only)
DB_SCHEMA_MODE=migrate
# DB_SYNC_ALTER: allow Sequelize sync to ALTER existing tables (non-destructive)
DB_SYNC_ALTER=false
# DB_SYNC_FORCE: drop and recreate all tables on startup (DESTRUCTIVE — dev only)
DB_SYNC_FORCE=false
# Safety guard: refuse schema sync if NODE_ENV=production
ALLOW_SCHEMA_SYNC_IN_PROD=false

# Connection retry parameters for services that start before Postgres is ready.
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=3000

# API gateway webhook database connection overrides.
DB_HOST=postgres
DB_NAME=webhooks
DB_USER=app_user
DB_PASSWORD=replace-with-strong-db-password

# =============================================================================
# 5) INFRA ENDPOINTS (Redis / Elasticsearch / Service URLs)
# =============================================================================
# Redis connection URL. Used for caching, sessions, pub/sub, and rate limiting.
REDIS_URL=redis://redis:6379
# Used by backup scripts (separate host/port form).
REDIS_HOST=redis
REDIS_PORT=6379

# Elasticsearch URL. Used by content-service for full-text search.
# Set ELASTICSEARCH_DISABLED=true to skip ES indexing if not needed.
ELASTICSEARCH_URL=http://elasticsearch:9200

# Internal service-to-service URLs (used by gateway and integration tests).
# These match the Docker Compose service names and internal ports.
USER_SERVICE_URL=http://user-service:8001
CONTENT_SERVICE_URL=http://content-service:8002
MESSAGING_SERVICE_URL=http://messaging-service:8003
COLLABORATION_SERVICE_URL=http://collaboration-service:8004
MEDIA_SERVICE_URL=http://media-service:8005
SHOP_SERVICE_URL=http://shop-service:8006
AI_SERVICE_URL=http://ai-service:8007
STREAMING_SERVICE_URL=http://streaming-service:8009

# =============================================================================
# 6) CORS / FRONTEND RUNTIME
# =============================================================================
# Public URL of the frontend application.
# For GitHub Codespaces: https://<codespace-name>-3000.app.github.dev
# For local: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Comma-separated allowed CORS origins for all backend services.
# Should match FRONTEND_URL. Add admin URL if admin panel is enabled.
CORS_ORIGINS=http://localhost:3000

# Frontend environment variables (injected at React build time).
# NOTE: Do NOT set REACT_APP_API_URL in Codespaces/dev containers —
#       use the CRA proxy instead (configured in frontend/package.json).
# For Codespaces: https://<codespace-name>-8000.app.github.dev
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_PROXY=http://localhost:8000
REACT_APP_MESSAGING_URL=http://localhost:8003
REACT_APP_MEDIA_URL=http://localhost:8005

# hCaptcha — bot protection for login/register forms.
# How to get: https://dashboard.hcaptcha.com -> New Site -> copy Site Key
# Site key is PUBLIC (safe to commit). Secret key is PRIVATE (backend only).
REACT_APP_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
HCAPTCHA_SECRET=your-hcaptcha-secret

# reCAPTCHA v3 (optional alternative to hCaptcha).
# How to get: https://www.google.com/recaptcha/admin/create
REACT_APP_RECAPTCHA_SITEKEY=

# Web push public key shown to frontend browsers (VAPID).
# NOTE: Must match VAPID_PUBLIC_KEY in section 9.
REACT_APP_VAPID_PUBLIC_KEY=

# Skip source map generation to reduce Docker image size.
GENERATE_SOURCEMAP=false

# =============================================================================
# 7) OAUTH PROVIDERS  [OPTIONAL — features disabled if empty]
# =============================================================================
# --- Google OAuth ---
# How to get: https://console.cloud.google.com -> APIs & Services -> Credentials
#             -> Create Credentials -> OAuth 2.0 Client IDs
# Reason: Allows users to sign in with Google account.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/google/callback

# --- GitHub OAuth ---
# How to get: https://github.com/settings/developers -> OAuth Apps -> New
# Reason: Allows users to sign in with GitHub account.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8001/oauth/github/callback

# --- Facebook OAuth (optional) ---
# How to get: https://developers.facebook.com -> My Apps -> Create App
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8001/oauth/facebook/callback

# --- Twitter/X OAuth (optional) ---
# How to get: https://developer.twitter.com -> Projects & Apps
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8001/oauth/twitter/callback

# --- LinkedIn OAuth (optional) ---
# How to get: https://www.linkedin.com/developers/apps/new
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8001/oauth/linkedin/callback

# --- Discord OAuth (optional) ---
# How to get: https://discord.com/developers/applications -> New Application -> OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Apple Sign-In (optional) ---
# How to get: https://developer.apple.com -> Certificates, IDs & Profiles -> Services
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# =============================================================================
# 8) EMAIL (Mailgun + SMTP fallback)
# =============================================================================
# --- Mailgun (primary email provider) ---
# How to get: https://app.mailgun.com -> Domains -> <your-domain> -> API Keys & SMTP
# Reason: Transactional email for signup verification, password reset, notifications.
#
# MAILGUN_API_KEY: Private API key (server-side sending — keep secret).
MAILGUN_API_KEY=
# MAILGUN_PUBLIC_KEY: Public validation key (for client-side email validation).
MAILGUN_PUBLIC_KEY=
# MAILGUN_SENDING_KEY: Sending-only API key (legacy format, may differ from API key).
MAILGUN_SENDING_KEY=
# MAILGUN_DOMAIN: Your verified sending domain (e.g. mg.yourdomain.com).
# Use 'sandbox.mailgun.org' for Mailgun sandbox testing (no real delivery).
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net
EMAIL_FROM=noreply@sandbox.mailgun.org

# --- SMTP fallback (used if MAILGUN_API_KEY is empty) ---
# For Gmail: use App Password (not your account password).
# How to get Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# 9) OBJECT STORAGE (MinIO / S3-compatible)
# =============================================================================
# MinIO runs inside Docker as an S3-compatible store for media uploads.
# In production, replace with real AWS S3 or compatible service.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3 bucket and connection (used by media-service).
# S3_ENDPOINT: Docker-internal MinIO URL. For AWS: leave empty (uses default AWS endpoint).
S3_BUCKET=milonexa-media
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Backup bucket (used by backup scripts).
S3_BACKUP_ENABLED=true
S3_BACKUP_BUCKET=backups

# =============================================================================
# 10) MESSAGING / PUSH NOTIFICATIONS / BOT TOKEN
# =============================================================================
# VAPID keypair for Web Push (PWA notifications).
# How to generate: npx web-push generate-vapid-keys
# Reason: Required by browsers to verify the push server identity.
# Generate ONCE and keep the private key safe. Changing it invalidates all
# existing push subscriptions (users must re-subscribe).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Internal system user ID for bot/automated messages.
# This is a fixed UUID — do not change after first deploy.
BOT_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001

# Telegram webhook bot token (for receiving webhook events, not admin bot).
# How to get: Talk to @BotFather on Telegram.
TELEGRAM_BOT_WEBHOOK_TOKEN=replace-with-strong-random-bot-token

# Firebase Cloud Messaging (optional, for Android push).
# How to get: https://console.firebase.google.com -> Project Settings -> Cloud Messaging
GCM_API_KEY=

# =============================================================================
# 11) AI SERVICE (Ollama local LLM + Google Gemini)
# =============================================================================
# --- Ollama (local LLM — runs entirely on your infrastructure) ---
# The ai-service container talks to the ollama container internally.
# No API key required — data never leaves your server.
#
# Default model: llama3.2 (3B params, fast, good for most tasks)
# Other options: phi3 (very lightweight), mistral, gemma2, llama3.1:8b
# First-run: the model is pulled automatically on container start (~2GB).
#
# Custom platform persona: after first start, run:
#   docker compose exec ollama ollama create letsconnect-ai -f /modelfiles/Modelfile
#   Then set OLLAMA_MODEL=letsconnect-ai
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2
# Timeout in milliseconds for Ollama inference (increase for slower hardware)
OLLAMA_TIMEOUT_MS=120000
# Number of parallel model inference requests (increase if you have GPU)
OLLAMA_NUM_PARALLEL=1

# --- Google Gemini (used by content-service for AI content moderation) ---
# How to get: https://aistudio.google.com/apikey -> Create API Key
# Reason: Powers toxicity scoring on posts (Post.toxicityScore field).
# Free tier available — no billing required for moderate usage.
GEMINI_API_KEY=replace-with-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# 12) COLLABORATION / RTC (WebRTC TURN server — optional)
# =============================================================================
# TURN server for WebRTC peer connections that can't connect directly (NAT traversal).
# Required for video/audio calls to work reliably across different networks.
# How to get: Self-host coturn (https://github.com/coturn/coturn) or
#             use a provider like Twilio, Metered.ca, or Cloudflare Calls.
TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=user
TURN_PASSWORD=pass

# =============================================================================
# 13) STREAMING SERVICE SEEDING
# =============================================================================
# Controls whether the streaming-service seeds its database with sample content.
# Set RUN_SEED=false to skip seeding entirely (recommended for CI/fast deploys).
RUN_SEED=true

# SEED_MODE: skip | minimal | full | fast | dry-run
#   skip    — no seed (fastest startup)
#   minimal — small dataset (SEED_MINIMAL_*_LIMIT rows each)
#   full    — complete dataset (slow, uses external APIs)
#   fast    — quick seed with validation/logo/enrichment disabled
SEED_MODE=minimal
# Fallback for older SEED_MODE env var format.
USE_FULL_SEED=false

SEED_MINIMAL_RADIO_LIMIT=50
SEED_MINIMAL_TV_LIMIT=50
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=100

# Fast-mode performance tuning
SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20
SEED_DB_CONNECT_RETRIES=3
SEED_DB_CONNECT_RETRY_DELAY_MS=2000
STREAMING_CACHE_DIR=/tmp/streaming-service-cache

# =============================================================================
# 14) BACKUP / RESTORE / OPS SCRIPTS
# =============================================================================
BACKUP_DIR=/backups
RETENTION_DAYS=30

# =============================================================================
# 15) ENTERPRISE / OPTIONAL INTEGRATIONS  [all optional]
# =============================================================================
# --- SAML SSO ---
# How to get: Configure your Identity Provider (Okta, Azure AD, etc.)
SAML_ENTITY_ID=milonexa-sp
SAML_IDP_URL=
SAML_IDP_CERT=
SAML_ACS_URL=http://localhost:8001/auth/saml/callback

# --- LDAP / Active Directory ---
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=

# --- Stripe (payment processing for shop-service) ---
# How to get: https://dashboard.stripe.com/apikeys
# Reason: Powers the shop/marketplace checkout flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Salesforce CRM ---
# How to get: https://developer.salesforce.com -> Connected Apps
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# --- Microsoft Teams ---
# How to get: https://portal.azure.com -> App registrations
TEAMS_WEBHOOK_URL=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# --- Jira ---
# How to get: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- ServiceNow ---
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# =============================================================================
# 16) E2E / CI TESTING
# =============================================================================
# Base URLs for end-to-end Playwright tests.
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_BASE_URL=http://localhost:8000/api
# Set true in CI to suppress interactive prompts.
CI=false
