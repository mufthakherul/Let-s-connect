# =============================================================================
# Milonexa - Categorized Environment Template
# =============================================================================
# Copy this file to `.env` and fill required values.
#
# How to collect values:
# - Random secrets/tokens: use a password manager or cryptographically secure generator.
# - OAuth credentials: create apps in provider developer consoles.
# - Mailgun/SMTP: use your email provider dashboard.
# - hCaptcha: create a site at hcaptcha.com and copy site/secret keys.
# - Gemini: generate API key in Google AI Studio.
# =============================================================================

# =============================================================================
# 1) Core Runtime
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
COMPOSE_PROJECT_NAME=milonexa
API_VERSION=v1

# Enable API gateway direct access in local development only.
ALLOW_DIRECT_SERVICE_ACCESS=false

# Global rate limiting toggle (gateway). true/false
RATE_LIMITING_ENABLED=true
# -------------------------
# Admin panel configuration
# -------------------------
# Optional separate frontend port (development only)
REACT_APP_ADMIN_PORT=3001
# Frontend secret used when admin panel calls backend
REACT_APP_ADMIN_SECRET=replace-with-admin-secret
# Backend gateway: optional security service port and admin secrets
# SECURITY_PORT is the port where the dedicated security-service listens
# (if set, the API gateway will proxy /admin to this port)
# default changed to 9102 to avoid common conflicts;
# update if you need a different port
SECURITY_PORT=9102
ADMIN_API_SECRET=replace-with-admin-api-secret      # must match the React secret
# Dynamic CORS origins for GitHub Codespaces (auto-generated from CODESPACE_NAME)
# Format: https://{CODESPACE_NAME}-{REACT_APP_ADMIN_PORT}.app.github.dev
ADMIN_CORS_ORIGINS=https://localhost:3001,http://localhost:3001
# Leave SECURITY_PORT unset to disable external admin service
# -------------------------
# Advanced Admin Security (Optional)
# -------------------------
# Enable 2FA for admin access (true/false)
ENABLE_ADMIN_2FA=false
# IP whitelisting for admin access (comma-separated IPs)
ADMIN_ALLOWED_IPS=127.0.0.1,::1
# IP range whitelisting (CIDR notation, comma-separated)
ADMIN_ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8

# -------------------------
# Admin Authentication & Database
# -------------------------
# Separate database connection string for admin accounts. Can point to
# its own Postgres database or schema.  Example:
# postgres://admin_user:pass@postgres:5432/milonexa_admin
ADMIN_DB_URL=postgres://app_user:replace-with-strong-db-password@postgres:5432/admin

# Master admin login (used to bootstrap, can create additional admins)
ADMIN_MASTER_USERNAME=admin
ADMIN_MASTER_PASSWORD=replace-with-strong-password
ADMIN_JWT_SECRET=replace-with-another-strong-secret
# =============================================================================
# 2) Security / Tokens (REQUIRED)
# =============================================================================
# Generate >= 32 random bytes, do NOT commit real values.
JWT_SECRET=replace-with-strong-random-jwt-secret
INTERNAL_GATEWAY_TOKEN=replace-with-strong-random-internal-token
INTERNAL_NOTIFICATION_TOKEN=replace-with-strong-random-notification-token
ENCRYPTION_KEY=replace-with-64-char-hex-or-strong-random-key

# =============================================================================
# 3) Database / Schema Policy
# =============================================================================
# Least-privilege app DB user consumed by docker-compose services.
APP_DB_USER=app_user
APP_DB_PASSWORD=replace-with-strong-db-password

# Postgres container bootstrap.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MULTIPLE_DATABASES=users,content,messages,collaboration,media,shop,webhooks,streaming

# Optional compatibility values used by some scripts/tools.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://app_user:replace-with-strong-db-password@postgres:5432/users

# Schema management strategy
# - migrate: safer, no broad sync
# - sync: auto sequelize sync
DB_SCHEMA_MODE=migrate
DB_SYNC_ALTER=false
DB_SYNC_FORCE=false
ALLOW_SCHEMA_SYNC_IN_PROD=false

# Connection retry tuning for some services
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=3000

# API gateway webhook database overrides
DB_HOST=postgres
DB_NAME=webhooks
DB_USER=app_user
DB_PASSWORD=replace-with-strong-db-password

# =============================================================================
# 4) Infra Endpoints (Redis / Search / Service URLs)
# =============================================================================
REDIS_URL=redis://redis:6379
ELASTICSEARCH_URL=http://elasticsearch:9200

# Optional service URL overrides (gateway/graphql/tests)
USER_SERVICE_URL=http://user-service:8001
CONTENT_SERVICE_URL=http://content-service:8002
MESSAGING_SERVICE_URL=http://messaging-service:8003

# =============================================================================
# 5) CORS / Frontend Runtime
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_PROXY=http://api-gateway:8000
REACT_APP_MESSAGING_URL=http://localhost:8003
REACT_APP_MEDIA_URL=http://localhost:8005

# Captcha keys (site keys are public in frontend, secrets are backend-only)
REACT_APP_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
REACT_APP_RECAPTCHA_SITEKEY=
HCAPTCHA_SECRET=your-hcaptcha-secret

# Web push/public key used by frontend PWA helper
REACT_APP_VAPID_PUBLIC_KEY=

# Frontend image build/runtime flags
GENERATE_SOURCEMAP=false

# =============================================================================
# 6) OAuth Providers
# =============================================================================
# Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/google/callback

# GitHub -> Settings -> Developer settings -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8001/oauth/github/callback

# Optional social providers
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8001/oauth/facebook/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8001/oauth/twitter/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8001/oauth/linkedin/callback

# =============================================================================
# 7) Email (Mailgun + SMTP fallback)
# =============================================================================
# Mailgun dashboard -> API Keys + Sending Domain
MAILGUN_API_KEY=
MAILGUN_PUBLIC_KEY=
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net
EMAIL_FROM=noreply@sandbox.mailgun.org

# SMTP fallback (if Mailgun not used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# 8) Object Storage (MinIO / S3)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_BUCKET=milonexa-media
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# =============================================================================
# 9) Messaging / Push / Bot
# =============================================================================
# Web push VAPID keypair (generate once and keep secret private key safe)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Internal bot/message fallback identity
BOT_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
TELEGRAM_BOT_WEBHOOK_TOKEN=replace-with-strong-random-bot-token

# =============================================================================
# 10) AI Service
# =============================================================================
# Google AI Studio -> API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# 11) Collaboration TURN / RTC (optional)
# =============================================================================
TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=user
TURN_PASSWORD=pass

# =============================================================================
# 12) Streaming Service Seeding
# =============================================================================
# RUN_SEED=false skips seed entirely.
RUN_SEED=true

# SEED_MODE: skip|minimal|full|fast
SEED_MODE=minimal
USE_FULL_SEED=false

SEED_MINIMAL_RADIO_LIMIT=50
SEED_MINIMAL_TV_LIMIT=50
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=100

SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20

# =============================================================================
# 13) Backup / Restore / Ops scripts
# =============================================================================
BACKUP_DIR=/backups
RETENTION_DAYS=30
S3_BACKUP_ENABLED=true
S3_BACKUP_BUCKET=backups
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# 14) Enterprise / Optional Integrations
# =============================================================================
# SAML
SAML_ENTITY_ID=milonexa-sp
SAML_IDP_URL=
SAML_IDP_CERT=
SAML_ACS_URL=http://localhost:8001/auth/saml/callback

# LDAP
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Microsoft Teams
TEAMS_WEBHOOK_URL=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# Jira
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# =============================================================================
# 15) E2E / CI
# =============================================================================
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_BASE_URL=http://localhost:8000/api
CI=false
