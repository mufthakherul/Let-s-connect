# =============================================================================
# Milonexa - Categorized Environment Template
# =============================================================================
# Copy this file to `.env` and fill required values.
#
# How to collect values:
# - Random secrets/tokens: use a password manager or cryptographically secure generator.
# - OAuth credentials: create apps in provider developer consoles.
# - Mailgun/SMTP: use your email provider dashboard.
# - hCaptcha: create a site at hcaptcha.com and copy site/secret keys.
# - Gemini: generate API key in Google AI Studio.
# =============================================================================

# =============================================================================
# 1) Core Runtime
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
COMPOSE_PROJECT_NAME=milonexa
API_VERSION=v1

# Enable API gateway direct access in local development only.
ALLOW_DIRECT_SERVICE_ACCESS=false

# Global rate limiting toggle (gateway). true/false
RATE_LIMITING_ENABLED=true
# -------------------------
# Admin panel configuration
# -------------------------
# ============================================================
# ADMIN PANEL INTERFACE CONTROLS
# Four admin interface methods are available:
#   1. CLI Admin Panel       — always available (local access only, no toggle)
#   2. Admin Frontend        — React UI on port 3001
#   3. Admin REST API        — HTTP REST API on port 8888
#   4. Admin SSH Dashboard     — SSH interactive shell on port 2222
#   5. Admin Webhook Server    — Notification delivery hub on port 8889 (NEW)
#   6. Admin Telegram Bot      — Telegram command bot (NEW)
#   7. Admin Slack Bot         — Slack admin bot via Socket Mode (NEW)
#   8. Admin Email Interface   — Email command interface via IMAP (NEW)
#
# All interfaces share the admin/ directory (unified structure).
# Default: only web dashboard is enabled (ENABLE_ADMIN_WEB=true).
# CLI is always available locally and has no toggle.
# ============================================================

# --- 1) Admin Web Dashboard (React UI) — ENABLED BY DEFAULT ---
# docker compose --profile admin up admin-web
ENABLE_ADMIN_WEB=true
# Admin web dashboard port
ADMIN_WEB_PORT=3001
# Frontend secret used when admin panel calls backend
REACT_APP_ADMIN_SECRET=replace-with-admin-secret
# Backend gateway: optional security service port and admin secrets
# SECURITY_PORT is the port where the dedicated security-service listens
SECURITY_PORT=9102
ADMIN_API_SECRET=replace-with-admin-api-secret      # must match the React secret
# Dynamic CORS origins for GitHub Codespaces (auto-generated from CODESPACE_NAME)
ADMIN_CORS_ORIGINS=https://localhost:3001,http://localhost:3001

# --- 2) Admin REST API Server ---
# Enable the HTTP REST API server for programmatic admin access.
# docker compose --profile admin-api up admin-rest-api
ENABLE_ADMIN_REST_API=false
# Port the REST API server listens on (default: 8888)
ADMIN_API_PORT=8888
# Bearer token for REST API authentication.
# REQUIRED when server listens on non-loopback addresses.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=replace-with-strong-random-key
# CORS origin for REST API (use specific domain in production)
ADMIN_CORS_ORIGIN=http://localhost:3001

# --- 3) Admin SSH Dashboard ---
# Enable the SSH-based interactive admin dashboard.
# docker compose --profile admin-ssh up admin-ssh
ENABLE_ADMIN_SSH=false
# Port for SSH admin dashboard (default: 2222)
ADMIN_SSH_PORT=2222
# Password for SSH 'admin' login.
# Leave empty to disable password auth (use key-only auth).
# Generate with: openssl rand -base64 24
ADMIN_SSH_PASSWORD=
# Path to authorized_keys file for public-key SSH auth.
ADMIN_SSH_AUTHORIZED_KEYS=./admin/ssh/ssh-keys/authorized_keys
# Directory containing your SSH public key files (mounted into container)
ADMIN_SSH_KEYS_DIR=./admin/ssh/ssh-keys
# Max simultaneous SSH sessions (default: 5)
ADMIN_SSH_MAX_SESSIONS=5
# Idle session timeout in seconds (default: 300 = 5 minutes)
ADMIN_SSH_IDLE_TIMEOUT=300
# Optional banner text shown to users on SSH connect
ADMIN_SSH_BANNER=Milonexa Admin SSH — Authorized Access Only

# --- 4) Admin Webhook Server (NEW) ---
# Standalone webhook notification server for Slack, Teams, PagerDuty, Discord alerts.
# docker compose --profile admin-webhook up admin-webhook
ENABLE_ADMIN_WEBHOOK=false
# Port for webhook server (default: 8889)
ADMIN_WEBHOOK_PORT=8889
# Secret for webhook server API auth. Generate: openssl rand -hex 32
ADMIN_WEBHOOK_SECRET=replace-with-strong-random-key

# --- 5) Admin Telegram Bot (NEW) ---
# Telegram bot for admin commands. Create a bot via @BotFather.
# docker compose --profile admin-bot-telegram up admin-bot-telegram
ENABLE_ADMIN_BOT_TELEGRAM=false
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use admin commands
TELEGRAM_ADMIN_USER_IDS=
# Comma-separated chat IDs (groups/channels) allowed for admin commands
TELEGRAM_ADMIN_CHAT_IDS=

# --- 6) Admin Slack Bot (NEW) ---
# Slack bot for admin commands via Socket Mode (no public URL needed).
# Setup: Create Slack app with Socket Mode, add slash commands, install to workspace.
# docker compose --profile admin-bot-slack up admin-bot-slack
ENABLE_ADMIN_BOT_SLACK=false
# Bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# Signing secret for request verification
SLACK_SIGNING_SECRET=
# Comma-separated Slack channel IDs where admin commands are allowed
SLACK_ADMIN_CHANNELS=
# Comma-separated Slack user IDs allowed to use admin commands
SLACK_ADMIN_USER_IDS=
# Port for Slack bolt HTTP mode (default: 3003, only used in HTTP mode)
SLACK_BOT_PORT=3003

# --- 7) Admin Email Command Interface (NEW) ---
# Accept admin commands via email. Send email to admin inbox with subject [ADMIN-CMD] <command>
# docker compose --profile admin-email up admin-email
ENABLE_ADMIN_EMAIL=false
# Email account credentials (shared for IMAP + SMTP fallback)
ADMIN_EMAIL_USER=
ADMIN_EMAIL_PASSWORD=
# IMAP server for reading incoming commands
ADMIN_EMAIL_IMAP_HOST=
ADMIN_EMAIL_IMAP_PORT=993
ADMIN_EMAIL_IMAP_TLS=true
# SMTP server for sending replies (optional overrides)
ADMIN_EMAIL_SMTP_HOST=
ADMIN_EMAIL_SMTP_PORT=587
ADMIN_EMAIL_SMTP_SECURE=false
ADMIN_EMAIL_SMTP_USER=
ADMIN_EMAIL_SMTP_PASS=
# From address for reply emails
ADMIN_EMAIL_FROM=
# ONLY these email addresses can send admin commands (comma-separated)
ADMIN_EMAIL_ALLOWED_SENDERS=
# Subject prefix for command emails (default: [ADMIN-CMD])
ADMIN_EMAIL_SUBJECT_PREFIX=[ADMIN-CMD]
# Optional: email body must contain this string for extra security
ADMIN_EMAIL_SIGNATURE=
# Polling interval in seconds (default: 30)
ADMIN_EMAIL_POLL_INTERVAL=30

# --- 8) AI Autonomous Admin Agent (v2.0) ---
# Next-generation AI-managed admin panel with code analysis, vulnerability scanning,
# auto-fix proposals, user feedback processing, documentation generation, and test generation.
# docker compose --profile admin-ai up admin-ai
ENABLE_ADMIN_AI=false

# AI provider: demo (rule-based, no API key), ollama (local LLM — recommended), openai, anthropic
# 'ollama' uses the local Ollama service — fully private, no external API key required.
# 'demo' mode works without any API key and uses built-in rule-based intelligence
AI_PROVIDER=ollama

# API keys (only needed if AI_PROVIDER=openai or anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# How often the AI agent runs its main monitoring cycle (seconds)
AI_CYCLE_INTERVAL_SECONDS=60

# Sub-cycle cadences: run each capability every N main cycles
# Code analysis (security scanning, bug detection, fix proposals)
AI_CODE_ANALYSIS_EVERY_N_CYCLES=10
# Documentation generation (LLM-written user guides per service)
AI_DOC_GEN_EVERY_N_CYCLES=20
# Test stub generation (untested route coverage)
AI_TEST_GEN_EVERY_N_CYCLES=30
# User feedback processing & feature suggestion
AI_FEEDBACK_EVERY_N_CYCLES=5

# Port for AI agent HTTP control/status API
# Available endpoints: GET /health, GET /status, GET /permissions,
#   POST /permissions/:id/approve, POST /permissions/:id/deny,
#   GET /code-analysis, POST /code-analysis/trigger,
#   GET /feedback, POST /feedback,
#   GET /docs, POST /docs/trigger,
#   GET /tests, POST /tests/trigger
AI_STATUS_PORT=8890

# Shared secret token for the AI agent HTTP control API.
# All endpoints except GET /health require `Authorization: Bearer <token>`.
# Leave empty only if the port is firewalled and never publicly reachable.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_STATUS_TOKEN=

# Send a notification after every cycle (true) or only when issues are found (false)
AI_NOTIFY_EVERY_CYCLE=false

# Always send notifications during emergency mode
AI_EMERGENCY_NOTIFY=true

# Allow AI to auto-heal non-critical issues without asking for human permission
AI_AUTO_HEAL=true

# Allow AI to auto-respond to low-severity security threats without human permission
AI_AUTO_SECURITY=true

# Platform API gateway URL (used for health checks)
AI_GATEWAY_URL=http://localhost:8000

# How long to wait for human permission approval before auto-expiring (minutes)
AI_PERMISSION_TIMEOUT_MINUTES=30

# -------------------------
# Advanced Admin Security (Optional)
# -------------------------
# Enable 2FA for admin access (true/false)
ENABLE_ADMIN_2FA=false
# IP whitelisting for admin access (comma-separated IPs, applies to REST API and SSH)
ADMIN_ALLOWED_IPS=127.0.0.1,::1
# IP range whitelisting (CIDR notation, comma-separated)
ADMIN_ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8

# -------------------------
# Admin Authentication & Database
# -------------------------
# Separate database connection string for admin accounts. Can point to
# its own Postgres database or schema.  Example:
# postgres://admin_user:pass@postgres:5432/milonexa_admin
ADMIN_DB_URL=postgres://app_user:replace-with-strong-db-password@postgres:5432/admin

# Master admin login (used to bootstrap, can create additional admins)
ADMIN_MASTER_USERNAME=admin
ADMIN_MASTER_PASSWORD=replace-with-strong-password
ADMIN_JWT_SECRET=replace-with-another-strong-secret
# =============================================================================
# 2) Security / Tokens (REQUIRED)
# =============================================================================
# Generate >= 32 random bytes, do NOT commit real values.
JWT_SECRET=replace-with-strong-random-jwt-secret
INTERNAL_GATEWAY_TOKEN=replace-with-strong-random-internal-token
INTERNAL_NOTIFICATION_TOKEN=replace-with-strong-random-notification-token
ENCRYPTION_KEY=replace-with-64-char-hex-or-strong-random-key

# =============================================================================
# 3) Database / Schema Policy
# =============================================================================
# Least-privilege app DB user consumed by docker-compose services.
APP_DB_USER=app_user
APP_DB_PASSWORD=replace-with-strong-db-password

# Postgres container bootstrap.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MULTIPLE_DATABASES=users,content,messages,collaboration,media,shop,webhooks,streaming

# Optional compatibility values used by some scripts/tools.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://app_user:replace-with-strong-db-password@postgres:5432/users

# Schema management strategy
# - migrate: safer, no broad sync
# - sync: auto sequelize sync
DB_SCHEMA_MODE=migrate
DB_SYNC_ALTER=false
DB_SYNC_FORCE=false
ALLOW_SCHEMA_SYNC_IN_PROD=false

# Connection retry tuning for some services
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=3000

# API gateway webhook database overrides
DB_HOST=postgres
DB_NAME=webhooks
DB_USER=app_user
DB_PASSWORD=replace-with-strong-db-password

# =============================================================================
# 4) Infra Endpoints (Redis / Search / Service URLs)
# =============================================================================
REDIS_URL=redis://redis:6379
ELASTICSEARCH_URL=http://elasticsearch:9200

# Optional service URL overrides (gateway/graphql/tests)
USER_SERVICE_URL=http://user-service:8001
CONTENT_SERVICE_URL=http://content-service:8002
MESSAGING_SERVICE_URL=http://messaging-service:8003

# =============================================================================
# 5) CORS / Frontend Runtime
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_PROXY=http://api-gateway:8000
REACT_APP_MESSAGING_URL=http://localhost:8003
REACT_APP_MEDIA_URL=http://localhost:8005

# Captcha keys (site keys are public in frontend, secrets are backend-only)
REACT_APP_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
REACT_APP_RECAPTCHA_SITEKEY=
HCAPTCHA_SECRET=your-hcaptcha-secret

# Web push/public key used by frontend PWA helper
REACT_APP_VAPID_PUBLIC_KEY=

# Frontend image build/runtime flags
GENERATE_SOURCEMAP=false

# =============================================================================
# 6) OAuth Providers
# =============================================================================
# Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/google/callback

# GitHub -> Settings -> Developer settings -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8001/oauth/github/callback

# Optional social providers
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8001/oauth/facebook/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8001/oauth/twitter/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8001/oauth/linkedin/callback

# =============================================================================
# 7) Email (Mailgun + SMTP fallback)
# =============================================================================
# Mailgun dashboard -> API Keys + Sending Domain
MAILGUN_API_KEY=
MAILGUN_PUBLIC_KEY=
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net
EMAIL_FROM=noreply@sandbox.mailgun.org

# SMTP fallback (if Mailgun not used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# 8) Object Storage (MinIO / S3)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_BUCKET=milonexa-media
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# =============================================================================
# 9) Messaging / Push / Bot
# =============================================================================
# Web push VAPID keypair (generate once and keep secret private key safe)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Internal bot/message fallback identity
BOT_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
TELEGRAM_BOT_WEBHOOK_TOKEN=replace-with-strong-random-bot-token

# =============================================================================
# 10) AI Service — Local LLM (Ollama)
# =============================================================================
# Ollama runs entirely on your own infrastructure — no data leaves your server.
# Models are stored in the ollama-data Docker volume.
#
# Default model: llama3.2 (fast, 3B params, great for most tasks)
# Other options: phi3 (very lightweight), mistral (higher quality), gemma2
#
# Custom Let's Connect persona: after first start, run:
#   docker compose exec ollama ollama create letsconnect-ai -f /modelfiles/Modelfile
#   Then set OLLAMA_MODEL=letsconnect-ai
#
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_TIMEOUT_MS=120000
# Number of parallel model requests (increase if you have GPU resources)
OLLAMA_NUM_PARALLEL=1

# =============================================================================
# 11) Collaboration TURN / RTC (optional)
# =============================================================================
TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=user
TURN_PASSWORD=pass

# =============================================================================
# 12) Streaming Service Seeding
# =============================================================================
# RUN_SEED=false skips seed entirely.
RUN_SEED=true

# SEED_MODE: skip|minimal|full|fast
SEED_MODE=minimal
USE_FULL_SEED=false

SEED_MINIMAL_RADIO_LIMIT=50
SEED_MINIMAL_TV_LIMIT=50
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=100

SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20

# =============================================================================
# 13) Backup / Restore / Ops scripts
# =============================================================================
BACKUP_DIR=/backups
RETENTION_DAYS=30
S3_BACKUP_ENABLED=true
S3_BACKUP_BUCKET=backups
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# 14) Enterprise / Optional Integrations
# =============================================================================
# SAML
SAML_ENTITY_ID=milonexa-sp
SAML_IDP_URL=
SAML_IDP_CERT=
SAML_ACS_URL=http://localhost:8001/auth/saml/callback

# LDAP
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Microsoft Teams
TEAMS_WEBHOOK_URL=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# Jira
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# =============================================================================
# 15) E2E / CI
# =============================================================================
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_BASE_URL=http://localhost:8000/api
CI=false
