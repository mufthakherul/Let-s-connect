# ==================== ENVIRONMENT VARIABLES TEMPLATE ====================
# Copy this to .env and fill in your values before running docker-compose up

# ==================== JWT & SECURITY ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data

DB_SYNC_ALTER=false

# ==================== DATABASE ====================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/users
POSTGRES_MULTIPLE_DATABASES=users,content,messages,collaboration,media,shop

# ==================== REDIS ====================
# Redis was previously required for rate limiting; no longer needed and can be left unset
# Toggle rate limiting on/off (true/false). Defaults to true if unset.
RATE_LIMITING_ENABLED=true

# ==================== ELASTICSEARCH ====================
ELASTICSEARCH_URL=http://elasticsearch:9200

# ==================== DOCKER & PORTS ====================
COMPOSE_PROJECT_NAME=lets-connect
API_GATEWAY_PORT=8000
NODE_ENV=development
GENERATE_SOURCEMAP=true
# React dev server tweaks ---------------------------------------------------
# Codespaces and other remote environments often trigger WebSocket handshake
# errors from the fast-refresh client.  Disabling fast refresh and forcing the
# socket path to the default prevents the noisy 404 messages during local
# development.
FAST_REFRESH=false
WDS_SOCKET_PATH=/sockjs-node
# ==================== MAILGUN EMAIL SERVICE ====================
# Get these from: https://app.mailgun.com/app/account/security/api_keys
# Instructions: Login to Mailgun → Account → Security & API Keys
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_PUBLIC_KEY=pubkey-xxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net
EMAIL_FROM=noreply@sandbox.mailgun.org

# ========== hCaptcha (set real keys for production) ==========
# Frontend site key (exposed to browser)
REACT_APP_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
# Server secret (verify with hCaptcha API)
HCAPTCHA_SECRET=your-hcaptcha-secret
# ============================================================

# ==================== GOOGLE OAUTH 2.0 ====================
# Get these from: https://console.cloud.google.com/apis/credentials
# Instructions:
#   1. Create new project or select existing
#   2. Enable Google+ API
#   3. Create OAuth 2.0 Credentials (Web application)
#   4. Set Authorized Redirect URI: http://localhost:8001/oauth/google/callback
#   5. Copy Client ID and Client Secret
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/google/callback

# ==================== GITHUB OAUTH 2.0 ====================
# Get these from: https://github.com/settings/developers
# Instructions:
#   1. Go to Settings → Developer settings → OAuth Apps
#   2. Create New OAuth App
#   3. Set Authorization callback URL: http://localhost:8001/oauth/github/callback
#   4. Copy Client ID and Client Secret
GITHUB_CLIENT_ID=Ov23lixxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REDIRECT_URI=http://localhost:8001/oauth/github/callback

# ==================== OBJECT STORAGE (MINIO/S3) ====================
S3_BUCKET=lets-connect-media
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ==================== AI SERVICES ====================
# Get GEMINI_API_KEY from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override model used by ai-service
GEMINI_MODEL=gemini-2.5-flash

# ==================== FRONTEND ====================
# REACT_APP_API_URL is used to override the automatic API host detection.
#
# In development the API gateway disables rate limiting entirely (NODE_ENV=development)
# so that rapid iteration in Codespaces or when clicking UI elements doesn't trigger
# 429 errors.  Production builds still enforce limits to protect against abuse.
# in development we force a relative path and use a proxy, so specifying a
# full url here often leads to CORS errors (see console).  leave blank or
# comment out when working locally.
# REACT_APP_API_URL=https://obscure-eureka-jjvx59qj5w763j56q-8000.github.dev

# ==================== PRODUCTION DEPLOYMENT ====================
# For production, uncomment and update the following:
# API_GATEWAY_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# MAILGUN_DOMAIN=mail.yourdomain.com
# EMAIL_FROM=noreply@yourdomain.com
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
# GITHUB_REDIRECT_URI=https://yourdomain.com/auth/github/callback
# NODE_ENV=production

# ==================== PHASE 8: ENTERPRISE FEATURES ====================

# ==================== ENTERPRISE AUTHENTICATION ====================
# SAML 2.0 Configuration
SAML_ENTITY_ID=lets-connect-sp
SAML_IDP_URL=https://idp.example.com/saml
SAML_IDP_CERT=MIIC...certificate-content...
SAML_ACS_URL=http://localhost:8001/auth/saml/callback

# LDAP/Active Directory Configuration
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin-password

# ==================== ENTERPRISE INTEGRATIONS ====================
# Salesforce Integration
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
TEAMS_CLIENT_ID=your-teams-client-id
TEAMS_CLIENT_SECRET=your-teams-client-secret
TEAMS_TENANT_ID=your-tenant-id

# Jira Integration
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ServiceNow Integration
SERVICENOW_INSTANCE=dev12345
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password

# ==================== SMTP EMAIL (Alternative to Mailgun) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@example.com

# ==================== FACEBOOK/META OAUTH ====================
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8001/oauth/facebook/callback

# ==================== TWITTER/X OAUTH ====================
# Get these from: https://developer.twitter.com/en/apps
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:8001/oauth/twitter/callback

# ==================== LINKEDIN OAUTH ====================
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8001/oauth/linkedin/callback

# ==================== INTERNAL TOKENS ====================
INTERNAL_NOTIFICATION_TOKEN=your-internal-notification-token

# ==================== MESSAGING WEBHOOK/BOT INTEGRATION ====================
# Fallback sender id used when external webhook payloads are persisted as messages
BOT_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
# Shared secret token for Telegram-style webhook endpoint
TELEGRAM_BOT_WEBHOOK_TOKEN=replace-with-secure-random-token

# ==================== Streaming Service Configuration ====================

# Seeding Configuration
# Canonical options: skip, minimal, full, fast
# - full: Fetch from all online sources and seed everything (slow, for production)
# - minimal: Use only static data, seed a small subset (fast, for development)
# - fast: Dynamic broad collection like full, with heavy checks disabled for speed
# - skip: Skip seeding entirely (fastest, when you already have data)
SEED_MODE=fast

# Backward compatibility only: when SEED_MODE is unset, USE_FULL_SEED=true => full
USE_FULL_SEED=false

# Maximum number of records to seed in minimal mode
SEED_MINIMAL_RADIO_LIMIT=5000
SEED_MINIMAL_TV_LIMIT=5000

# Seeding behavior flags
# seed-fast.js is for minimal static mode; seed.js handles full/fast dynamic modes
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=10000

# Fast mode tuning (used by seed.js when SEED_MODE=fast)
SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20

