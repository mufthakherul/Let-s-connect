# Render Deployment - Ignore documentation files
# Note: Documentation files in the root are force-committed (git add -f)
# This .gitignore is primarily for Render deployment to reduce deploy size

# Environment files (never commit these)
.env
.env.local
.env.*.local

# Documentation (already tracked files are not affected)
#*.md
# !README.md
#docs/
#archives/

# Development files
.git/
.github/
# Allow editor and devcontainer files for remote development (do not ignore)
# .vscode/
# .devcontainer/

# Docker files — keep Dockerfiles and compose for local/remote development
# Previously ignored for Render deployments; commented out to allow development
# docker-compose.yml
# Dockerfile
# **/Dockerfile

# Testing
#tests/
#*.test.js
#*.spec.js

# CI/CD
# .gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# IDE
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store

# Temporary files
tmp/
temp/
*.log
*.swp
*.swo
*.tmp
*.cache
.cache/
node_modules/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
gateway_logs.txt
# Temporary test output files
scripts/.tmp-*.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.local
.env.production

# Build outputs
dist/
build/
out/

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
#public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Database files
*.db
*.sqlite
*.sqlite3

# Archive and backup directories
# NOTE: Archives/ (capital A) is the canonical archive directory and IS tracked
archive_code/
archives/
*.backup
*~

# Admin frontend
/admin_frontend/node_modules/
/admin_frontend/build/


# Large files
*.zip
*.tar.gz
*.rar

# Scripts (unless needed)
# Allow project scripts to be tracked for development
# scripts/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
build/
dist/
*.tsbuildinfo

