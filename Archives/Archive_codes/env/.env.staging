# Staging Environment Configuration
# Used for pre-production testing and integration validation
# Values here are placeholders; actual secrets stored in GitHub/Vault

# Core Runtime
NODE_ENV=staging
LOG_LEVEL=info
PORT=3000
API_GATEWAY_PORT=8000

# API Gateway
API_GATEWAY_TIMEOUT=45000
API_GATEWAY_RETRY_ATTEMPTS=3
API_GATEWAY_LOG_LEVEL=info
API_VERSION=v2

# Admin Panel
ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_PORT=3001

# Authentication
JWT_SECRET=${{ secrets.JWT_SECRET_STAGING }}
JWT_EXPIRY=72h
ADMIN_JWT_EXPIRY=24h

# OAuth2
GOOGLE_CLIENT_ID=${{ secrets.GOOGLE_CLIENT_ID_STAGING }}
GOOGLE_CLIENT_SECRET=${{ secrets.GOOGLE_CLIENT_SECRET_STAGING }}

# Database
DATABASE_URL=${{ secrets.DATABASE_URL_STAGING }}
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000
DATABASE_SSL=true
DATABASE_LOG=false

# Cache
REDIS_URL=${{ secrets.REDIS_URL_STAGING }}
REDIS_CACHE_TTL=7200
REDIS_POOL_SIZE=10

# Email
EMAIL_SERVICE=smtp
EMAIL_FROM=staging-noreply@milonexa.com
SMTP_HOST=${{ secrets.SMTP_HOST_STAGING }}
SMTP_PORT=${{ secrets.SMTP_PORT_STAGING }}
SMTP_USER=${{ secrets.SMTP_USER_STAGING }}
SMTP_PASS=${{ secrets.SMTP_PASS_STAGING }}

# Storage
STORAGE_TYPE=s3
S3_ENDPOINT=${{ secrets.S3_ENDPOINT_STAGING }}
S3_BUCKET=${{ secrets.S3_BUCKET_STAGING }}
S3_REGION=${{ secrets.S3_REGION_STAGING }}
S3_ACCESS_KEY=${{ secrets.S3_ACCESS_KEY_STAGING }}
S3_SECRET_KEY=${{ secrets.S3_SECRET_KEY_STAGING }}
S3_SSL=true
MAX_FILE_SIZE=52428800

# Media Settings
MEDIA_IMAGE_MAX_SIZE=5242880
MEDIA_VIDEO_MAX_SIZE=104857600
MEDIA_ALLOWED_FORMATS=jpg,jpeg,png,gif,mp4,webm,mov

# Search (Elasticsearch)
ELASTICSEARCH_URL=${{ secrets.ELASTICSEARCH_URL_STAGING }}
ELASTICSEARCH_USERNAME=${{ secrets.ELASTICSEARCH_USER_STAGING }}
ELASTICSEARCH_PASSWORD=${{ secrets.ELASTICSEARCH_PASSWORD_STAGING }}
ELASTICSEARCH_INDEX_PREFIX=milonexa-staging
ELASTICSEARCH_LOG_LEVEL=warn

# AI Service
AI_SERVICE_ENABLED=true
OPENAI_API_KEY=${{ secrets.OPENAI_API_KEY_STAGING }}
OPENAI_MODEL=gpt-4
AI_CONTENT_MODERATION_ENABLED=true
AI_RATE_LIMIT_ENABLED=true

# Monitoring & Logging
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
LOG_AGGREGATION=elasticsearch
DATADOG_ENABLED=true
DATADOG_API_KEY=${{ secrets.DATADOG_API_KEY_STAGING }}
DATADOG_APP_KEY=${{ secrets.DATADOG_APP_KEY_STAGING }}

# Feature Flags
FEATURE_BETA_COLLABORATION=true
FEATURE_BETA_STREAMING=true
FEATURE_SHOP_CHECKOUT=true

# Security
CORS_ORIGIN=https://staging.milonexa.com,https://staging-admin.milonexa.com
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_ENABLED=true
REQUIRE_HTTPS=true
REQUIRE_API_KEY_AUTH=false

# SSL/TLS
SSL_CERT_PATH=/etc/tls/staging/cert.pem
SSL_KEY_PATH=/etc/tls/staging/key.pem

# Error Tracking
SENTRY_DSN=${{ secrets.SENTRY_DSN_STAGING }}
SENTRY_ENVIRONMENT=staging
SENTRY_ENABLED=true

# Debug
DEBUG_MODE=false
DEBUG_SQL_QUERIES=false
LOG_SENSITIVE_DATA=false
