{
    "dashboard": {
        "title": "Milonexa - System Overview",
        "tags": [
            "milonexa",
            "overview"
        ],
        "timezone": "browser",
        "schemaVersion": 27,
        "version": 0,
        "refresh": "30s",
        "panels": [
            {
                "id": 1,
                "title": "Service Health Status",
                "type": "stat",
                "gridPos": {
                    "x": 0,
                    "y": 0,
                    "w": 24,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "up{job=~\"api-gateway|user-service|content-service|messaging-service\"}",
                        "legendFormat": "{{ job }}",
                        "refId": "A"
                    }
                ],
                "options": {
                    "graphMode": "none",
                    "colorMode": "background",
                    "orientation": "horizontal"
                },
                "fieldConfig": {
                    "defaults": {
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "value": 0,
                                    "color": "red"
                                },
                                {
                                    "value": 1,
                                    "color": "green"
                                }
                            ]
                        },
                        "mappings": [
                            {
                                "type": "value",
                                "value": "0",
                                "text": "DOWN"
                            },
                            {
                                "type": "value",
                                "value": "1",
                                "text": "UP"
                            }
                        ]
                    }
                }
            },
            {
                "id": 2,
                "title": "Request Rate (req/s)",
                "type": "graph",
                "gridPos": {
                    "x": 0,
                    "y": 4,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "rate(http_requests_total[5m])",
                        "legendFormat": "{{ job }} - {{ method }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "reqps",
                        "label": "Requests/sec"
                    },
                    {
                        "format": "short"
                    }
                ]
            },
            {
                "id": 3,
                "title": "Response Time (p95)",
                "type": "graph",
                "gridPos": {
                    "x": 12,
                    "y": 4,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
                        "legendFormat": "{{ job }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "s",
                        "label": "Response Time"
                    },
                    {
                        "format": "short"
                    }
                ]
            },
            {
                "id": 4,
                "title": "Error Rate",
                "type": "graph",
                "gridPos": {
                    "x": 0,
                    "y": 12,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
                        "legendFormat": "{{ job }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "percentunit",
                        "label": "Error Rate"
                    },
                    {
                        "format": "short"
                    }
                ]
            },
            {
                "id": 5,
                "title": "Circuit Breaker States",
                "type": "graph",
                "gridPos": {
                    "x": 12,
                    "y": 12,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "circuit_breaker_state",
                        "legendFormat": "{{ service }} - {{ state }}",
                        "refId": "A"
                    }
                ]
            },
            {
                "id": 6,
                "title": "CPU Usage",
                "type": "graph",
                "gridPos": {
                    "x": 0,
                    "y": 20,
                    "w": 8,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
                        "legendFormat": "{{ instance }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "percent",
                        "label": "CPU %"
                    },
                    {
                        "format": "short"
                    }
                ]
            },
            {
                "id": 7,
                "title": "Memory Usage",
                "type": "graph",
                "gridPos": {
                    "x": 8,
                    "y": 20,
                    "w": 8,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
                        "legendFormat": "{{ instance }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "percent",
                        "label": "Memory %"
                    },
                    {
                        "format": "short"
                    }
                ]
            },
            {
                "id": 8,
                "title": "Database Connections",
                "type": "graph",
                "gridPos": {
                    "x": 16,
                    "y": 20,
                    "w": 8,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "pg_stat_activity_count",
                        "legendFormat": "Active Connections",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "short",
                        "label": "Connections"
                    },
                    {
                        "format": "short"
                    }
                ]
            }
        ]
    }
}