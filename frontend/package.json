{
  "name": "milonexa-frontend",
  "version": "1.0.0",
  "description": "Frontend for Milonexa platform",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "@mui/x-tree-view": "^8.27.2",
    "@tanstack/react-query": "^5.28.4",
    "@types/react-window": "^1.8.8",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.1.3",
    "emoji-picker-react": "^4.9.2",
    "framer-motion": "^12.35.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.4.1",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^7.13.1",
    "react-window": "^1.8.10",
    "recharts": "^3.8.1",
    "shaka-player": "^5.0.5",
    "socket.io-client": "^4.7.4",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:admin": "PORT=3001 BROWSER=none react-scripts start",
    "prebuild": "node scripts/strip-shaka-sourcemaps.js",
    "build": "react-scripts build",
    "check:bundle": "node scripts/check-build-budget.js",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings 50",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "eject": "react-scripts eject",
    "postinstall": "node -e \"const fs=require('fs');['shaka-player.ui.js','controls.css'].forEach(file=>{const p='./node_modules/shaka-player/dist/'+file;try{if(fs.existsSync(p)){let c=fs.readFileSync(p,'utf8');c=c.replace(/(^|\\n)\\/\\/# sourceMappingURL=.*$/gm,'');c=c.replace(/\\/\\*# sourceMappingURL=[^*]*\\*\\//gm,'');fs.writeFileSync(p,c,'utf8');}}catch(_){}});\""
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.2",
    "react-scripts": "^5.0.1",
    "typescript": "^5.9.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
