# Streaming Service Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/streaming

# Seeding Configuration
# Canonical options: skip, minimal, full, fast
# - full: Fetch from all online sources and seed everything (slow, for production)
# - minimal: Use only static data, seed a small subset (fast, for development)
# - fast: Dynamic broad collection like full, with heavy checks disabled for speed
# - skip: Skip seeding entirely (fastest, when you already have data)
SEED_MODE=minimal

# Backward compatibility only: when SEED_MODE is unset, USE_FULL_SEED=true => full
USE_FULL_SEED=false

# Maximum number of records to seed in minimal mode
SEED_MINIMAL_RADIO_LIMIT=50
SEED_MINIMAL_TV_LIMIT=50

# Seeding behavior flags
# seed-fast.js is for minimal static mode; seed.js handles full/fast dynamic modes
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=100

# Fast mode tuning (used by seed.js when SEED_MODE=fast)
SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20

# Service port
PORT=3009
