# Streaming Service - Environment Example
# Prefer using repository root `.env` for docker-compose deployments.

# Runtime
NODE_ENV=production
PORT=8009

# Database
DATABASE_URL=postgresql://app_user:replace-with-strong-db-password@postgres:5432/streaming
DB_SCHEMA_MODE=migrate
DB_SYNC_ALTER=false

# Seed control
RUN_SEED=true
SEED_MODE=minimal         # skip|minimal|full|fast|dry-run
USE_FULL_SEED=false       # backward compatibility fallback

# Minimal mode limits
SEED_MINIMAL_RADIO_LIMIT=50
SEED_MINIMAL_TV_LIMIT=50

# Seed behavior
SEED_SKIP_ONLINE_FETCH=false
SEED_SKIP_VALIDATION=true
SEED_SKIP_ENRICHMENT=true
SEED_BATCH_SIZE=100

# Fast mode tuning
SEED_FAST_DISABLE_STREAM_VALIDATION=true
SEED_FAST_DISABLE_LOGO_NETWORK=true
SEED_FAST_DISABLE_YOUTUBE_ENRICHMENT=true
SEED_FAST_DISABLE_DELAYS=true
SEED_FAST_SKIP_PER_ITEM_PRECHECK=true
SEED_CHUNK_DELAY_MS=0
SEED_CHANNEL_ENRICH_MAX_CONCURRENT=20
STREAMING_CACHE_DIR=/tmp/streaming-service-cache

# Internal auth (when not behind gateway in dev)
INTERNAL_GATEWAY_TOKEN=replace-with-strong-random-token
